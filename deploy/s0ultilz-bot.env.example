# Telegram bot token
TELEGRAM_BOT_TOKEN=0000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Paths to external tools (if they are in PATH, you can leave as-is)
YTDLP_PATH=yt-dlp
GALLERYDL_PATH=gallery-dl
FFMPEG_PATH=ffmpeg

# Optional: Netscape cookies.txt for Instagram (for private/limited posts)
# Leave empty to work only with public content
